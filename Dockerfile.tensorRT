# TensorRT-LLM Deployment for SAP AI Core
# Optimized for pre-converted checkpoints with INT4 AWQ + INT8 KV cache
# Uses TensorRT-LLM version bundled with the Triton Server base image

# Base image includes TensorRT-LLM (25.01 release)
FROM nvcr.io/nvidia/tritonserver:25.01-trtllm-python-py3

ENV LANG=C.UTF-8
ENV DEBIAN_FRONTEND=noninteractive

# Install additional dependencies (TensorRT-LLM is already in the base image)
RUN apt-get update && apt-get install -y git git-lfs && rm -rf /var/lib/apt/lists/* && \
    pip3 install --upgrade pip && \
    pip3 install huggingface_hub transformers sentencepiece protobuf

# SAP AI Core Permissions & Directory Setup
RUN mkdir -p /nonexistent/ /hf-home/ /engines/ /checkpoint/ && \
    chown -R nobody:nogroup /nonexistent /hf-home/ /engines/ /checkpoint/ && \
    chmod -R 770 /nonexistent/ /hf-home/ /engines/ /checkpoint/

ENV HF_HOME=/hf-home
ENV TRT_ENGINE_DIR=/engines
ENV CHECKPOINT_DIR=/checkpoint

COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

EXPOSE 8000
ENTRYPOINT ["/entrypoint.sh"]