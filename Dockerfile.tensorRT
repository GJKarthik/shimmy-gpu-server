# TensorRT-LLM Deployment for SAP AI Core
# Optimized for pre-converted checkpoints with INT4 AWQ + INT8 KV cache
# Uses TensorRT-LLM version bundled with the Triton Server base image

# Base image includes TensorRT-LLM (25.01 release)
FROM nvcr.io/nvidia/tritonserver:25.01-trtllm-python-py3

ENV LANG=C.UTF-8
ENV DEBIAN_FRONTEND=noninteractive

# Install git/git-lfs for model downloads (Python packages already in base image)
RUN apt-get update && apt-get install -y git git-lfs && rm -rf /var/lib/apt/lists/*

# SAP AI Core Permissions & Directory Setup
# TensorRT-LLM writes model.cache to current working directory
RUN mkdir -p /nonexistent/ /hf-home/ /engines/ /checkpoint/ /workspace/ && \
    chown -R nobody:nogroup /nonexistent /hf-home/ /engines/ /checkpoint/ /workspace/ && \
    chmod -R 777 /nonexistent/ /hf-home/ /engines/ /checkpoint/ /workspace/

ENV HF_HOME=/hf-home
ENV TRT_ENGINE_DIR=/engines
ENV CHECKPOINT_DIR=/checkpoint

# Set writable working directory for TensorRT cache files
WORKDIR /workspace

COPY entrypoint.sh /entrypoint.sh
COPY serve_t4.py /serve_t4.py
RUN chmod +x /entrypoint.sh /serve_t4.py

EXPOSE 8000
ENTRYPOINT ["/entrypoint.sh"]